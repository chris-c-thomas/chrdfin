{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chrdfin",
  "version": "0.0.1",
  "identifier": "com.chrdfin.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter desktop dev",
    "beforeBuildCommand": "pnpm --filter desktop build"
  },
  "app": {
    "windows": [
      {
        "title": "chrdfin",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Chris Thomas",
    "homepage": "https://github.com/chris-c-thomas/chrdfin",
    "copyright": "Copyright © 2026 Chris Thomas",
    "category": "Finance",
    "shortDescription": "Personal financial intelligence desktop workstation.",
    "longDescription": "chrdfin is a personal financial intelligence desktop application: multi-instance portfolio tracking, backtesting, Monte Carlo simulation, optimization, calculators, market data, news, calendars, and a bundled reference library. Built with Tauri v2, React 19, and embedded DuckDB.",
    "licenseFile": "../../../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
