{
  "name": "@chrdfin/ui",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "Shared UI component library for chrdfin (shadcn/ui-derived primitives, sidebar, formatters, DeltaValue). Internal workspace package — not published.",
  "author": {
    "name": "Chris Thomas",
    "email": "chris.c.thomas@icloud.com",
    "url": "https://github.com/chris-c-thomas"
  },
  "homepage": "https://github.com/chris-c-thomas/chrdfin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chris-c-thomas/chrdfin.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/chris-c-thomas/chrdfin/issues"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./lib/utils": "./src/lib/utils.ts",
    "./lib/format": "./src/lib/format.ts",
    "./components/*": "./src/components/*.tsx",
    "./components/ui/*": "./src/components/ui/*.tsx"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@chrdfin/config": "workspace:*",
    "@chrdfin/types": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "lucide-react": "^0.469.0",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@chrdfin/eslint-config": "workspace:*",
    "@chrdfin/tsconfig": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
